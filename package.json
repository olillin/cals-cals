    "bugs": {
        "url": "https://github.com/olillin/cals-cals/issues"
    },
    "homepage": "https://cal.olillin.com",
    "packageManager": "pnpm@10.28.0",
    "dependencies": {
        "ajv": "^8.18.0",
        "chalmers-search-exam": "^3.0.0",
        "clsx": "^2.1.1",
        "iamcal": "^4.0.0",
        "next": "^16.1.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^9.39.3",
        "@tailwindcss/postcss": "^4.2.1",
        "@types/node": "^24.10.14",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.39.3",
        "eslint-config-next": "16.0.0",
        "eslint-plugin-jsdoc": "^62.7.1",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.18"
    }
